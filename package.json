{
  "name": "elegant-tide",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "android:sync": "pnpm --filter @elegant-tide/mobile sync",
    "android:open": "pnpm --filter @elegant-tide/mobile open:android",
    "android:build": "pnpm --filter @elegant-tide/mobile build",
    "e2e": "pnpm --filter @elegant-tide/e2e test",
    "e2e:ui": "pnpm --filter @elegant-tide/e2e test:ui"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "prettier": "^3.5.3"
  }
}
