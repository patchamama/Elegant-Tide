{
  "name": "@elegant-tide/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^22.15.21",
    "electron": "^36.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.elegant-tide.desktop",
    "productName": "Elegant Tide",
    "directories": {
      "output": "dist/package"
    },
    "files": ["dist/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "AudioVideo"
    },
    "publish": {
      "provider": "generic",
      "url": "https://releases.elegant-tide.com"
    }
  }
}
